{"defs":{},"properties":[{"path":["id"],"id":"@id","description":"The persistent or local URI identifying this object.","schema_type":"string","format":"uri","sources":["bblocks://ogc.heritage.heritage-object"],"effectiveId":"@id"},{"path":["type"],"id":"@type","const":"HeritageObject","sources":["bblocks://ogc.heritage.heritage-object"],"effectiveId":"@type"},{"path":["identifier"],"id":"http://www.cidoc-crm.org/cidoc-crm/P1_is_identified_by","description":"A local catalogue or inventory number (CIDOC-CRM P1_is_identified_by).","required":true,"schema_type":"string","sources":["bblocks://ogc.heritage.heritage-object"],"effectiveId":"http://www.cidoc-crm.org/cidoc-crm/P1_is_identified_by"},{"path":["title"],"id":"http://www.cidoc-crm.org/cidoc-crm/P102_has_title","description":"A human-readable title or name for the object (CIDOC-CRM P102_has_title).","required":true,"schema_type":"string","sources":["bblocks://ogc.heritage.heritage-object"],"effectiveId":"http://www.cidoc-crm.org/cidoc-crm/P102_has_title"},{"path":["description"],"id":"http://www.cidoc-crm.org/cidoc-crm/P3_has_note","description":"Free-text description or curatorial note (CIDOC-CRM P3_has_note).","schema_type":"string","sources":["bblocks://ogc.heritage.heritage-object"],"effectiveId":"http://www.cidoc-crm.org/cidoc-crm/P3_has_note"},{"path":["objectType"],"id":"http://www.cidoc-crm.org/cidoc-crm/P2_has_type","jsonld_type":"@id","description":"The type of object, typically a Getty AAT concept URI (CIDOC-CRM P2_has_type).","schema_type":"string","format":"uri","sources":["bblocks://ogc.heritage.heritage-object"],"effectiveId":"http://www.cidoc-crm.org/cidoc-crm/P2_has_type"},{"path":["material"],"id":"http://www.cidoc-crm.org/cidoc-crm/P45_consists_of","jsonld_type":"@id","description":"Materials the object consists of, typically Getty AAT concept URIs (CIDOC-CRM P45_consists_of).","schema_type":"array","sources":["bblocks://ogc.heritage.heritage-object"],"effectiveId":"http://www.cidoc-crm.org/cidoc-crm/P45_consists_of"},{"path":["currentLocation"],"id":"http://www.cidoc-crm.org/cidoc-crm/P53_has_former_or_current_location","jsonld_type":"@id","description":"URI of the place where the object is currently or was last located (CIDOC-CRM P53_has_former_or_current_location).","schema_type":"string","format":"uri","sources":["bblocks://ogc.heritage.heritage-object"],"effectiveId":"http://www.cidoc-crm.org/cidoc-crm/P53_has_former_or_current_location"},{"path":["persistentIdentifier"],"id":"http://www.cidoc-crm.org/cidoc-crm/P1_is_identified_by","jsonld_type":"@id","description":"A persistent identifier (e.g. ARK, DOI, Handle) minted for this object.","schema_type":"string","format":"uri","sources":["bblocks://ogc.heritage.heritage-object"],"effectiveId":"http://www.cidoc-crm.org/cidoc-crm/P1_is_identified_by"}]}