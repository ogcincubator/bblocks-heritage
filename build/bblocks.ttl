<https://ogcincubator.github.io/bblocks-heritage/> a skos:ConceptScheme,
        dcat:Catalog,
        bblocks:BBlocksRegister ;
    rdfs:label "Building Blocks - Cultural Heritage Building Blocks" ;
    dct:abstract """Reusable OGC Building Blocks for modelling cultural heritage data, covering heritage objects,
digital representations, provenance, sensor observations and dataset metadata.
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:description """This register defines reusable, machine-readable specification components for the cultural
heritage domain, building on CIDOC-CRM, PROV-O, SOSA/SSN, EDM and DCAT. It originated from the
standards profiling work of the [HERITALISE](https://heritalise.eu) project (deliverables D8.1
and D8.2), but is intended as a general-purpose register usable beyond that project.
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:modified "2026-06-25T14:31:05.207132"^^xsd:dateTime ;
    owl:imports <https://ogcincubator.github.io/bblock-prov-schema/build/register.json>,
        <https://ogcincubator.github.io/bblocks-skos/build/register.json>,
        <https://ogcincubator.github.io/bblocks-sta/build/register.json>,
        <https://ogcincubator.github.io/geodcat-ogcapi-records/build/register.json>,
        <https://opengeospatial.github.io/bblocks/register.json> ;
    skos:hasTopConcept <bblocks://ogc.heritage.actor>,
        <bblocks://ogc.heritage.aggregation>,
        <bblocks://ogc.heritage.archival-document>,
        <bblocks://ogc.heritage.digital-representation>,
        <bblocks://ogc.heritage.event>,
        <bblocks://ogc.heritage.fabrication-output>,
        <bblocks://ogc.heritage.heritage-object>,
        <bblocks://ogc.heritage.observation>,
        <bblocks://ogc.heritage.place>,
        <bblocks://ogc.heritage.three-d-model> ;
    skos:prefLabel "Building Blocks - Cultural Heritage Building Blocks" ;
    prof:hasResource [ rdfs:label "This Building Blocks Register in JSON format" ;
            dct:type "application/json" ;
            ns2:relation <http://www.iana.org/assignments/relation/self> ;
            ns1:hasTarget <https://ogcincubator.github.io/bblocks-heritage/build/register.json> ],
        [ rdfs:label "This Building Blocks Register in RDF Turtle format" ;
            dct:type "text/turtle" ;
            ns2:relation <http://www.iana.org/assignments/relation/self> ;
            ns1:hasTarget <https://ogcincubator.github.io/bblocks-heritage/build/bblocks.ttl> ],
        [ rdfs:label "This Building Blocks Register in JSON-LD format" ;
            dct:type "application/ld+json" ;
            ns2:relation <http://www.iana.org/assignments/relation/self> ;
            ns1:hasTarget <https://ogcincubator.github.io/bblocks-heritage/build/bblocks.jsonld> ] ;
    foaf:homepage <https://ogcincubator.github.io/bblocks-heritage/> ;
    bblocks:hasValidationReport <https://ogcincubator.github.io/bblocks-heritage/build/tests/report.html> .

